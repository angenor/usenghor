# ===========================================
# USenghor Production Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database
POSTGRES_USER=usenghor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=usenghor

# Application secrets (generate with: openssl rand -hex 32)
APP_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_JWT_SECRET

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=https://usenghor.org,https://www.usenghor.org

# Frontend API URL (internal Docker network)
NUXT_PUBLIC_API_BASE=http://backend:8000
NUXT_PUBLIC_API_BASE_URL=http://backend:8000

# Site URL (for sitemap generation)
NUXT_SITE_URL=http://137.74.117.231

# SMTP (Email configuration)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@usenghor.org
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=noreply@usenghor.org
